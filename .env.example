# ==================== 数据库 ====================
DATABASE_URL=sqlite:///./finance_data.db
ECHO_SQL=False  # 调试时设为 True，会打印 SQL 语句

# ==================== 微信推送（阶段 3） ====================
# Server 酱 (https://sct.ftqq.com) - 注册后获取 SendKey
SERVERCHAN_SENDKEY=

# PushPlus 备选方案 (https://pushplus.plus)
PUSHPLUS_TOKEN=

# ==================== 盯盘告警配置 ====================
# 告警冷却时间（分钟），同一规则触发后 N 分钟内不再重复发送
ALERT_COOLDOWN_MINUTES=30

# 盯盘循环轮询间隔（秒）
MONITOR_INTERVAL_SECONDS=60

# ==================== 日志 ====================
LOG_LEVEL=INFO
